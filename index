<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>บันทึกผลงานกรรมการสงเคราะห์</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <style>
        body { background-color: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
        .container-liff { max-width: 600px; margin: auto; padding: 20px; }
        .card-form { border-radius: 20px; border: none; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
        .header-title { color: #0d6efd; font-weight: 800; }
        .section-special { display: none; border-left: 4px solid #0d6efd; background-color: #f8f9ff; padding: 15px; border-radius: 0 10px 10px 0; margin-top: 15px; }
        .form-label { font-weight: 600; color: #444; }
        .btn-submit { background-color: #0d6efd; color: white; border-radius: 12px; padding: 12px; font-weight: bold; width: 100%; border: none; }
    </style>
</head>
<body>

<div class="container-liff">
    <div class="card card-form p-4">
        <div class="text-center mb-4">
            <h4 class="header-title"><i class="bi bi-pencil-square"></i> บันทึกผลงานกรรมการ</h4>
            <p class="text-muted small">สถานพินิจฯ จังหวัดขอนแก่น (GitHub Version)</p>
        </div>

        <form id="perfForm" class="row g-3">
            <div class="col-4">
                <label class="form-label">ปี พ.ศ.</label>
                <input type="number" id="year" class="form-control" value="2569" required>
            </div>
            <div class="col-8">
                <label class="form-label">ชื่อกรรมการ</label>
                <input type="text" id="volunteerName" class="form-control bg-light" readonly required>
            </div>

            <div class="col-12">
                <label class="form-label">ประเภทผลงาน</label>
                <select id="mainType" class="form-select" onchange="updateSubOptions()" required>
                    <option value="">เลือกประเภทหลัก...</option>
                    <option value="ผลงานทั่วไป">ผลงานทั่วไป</option>
                    <option value="ผลงานเฉพาะ">ผลงานเฉพาะ</option>
                </select>
            </div>

            <div class="col-12">
                <label class="form-label">รายการผลงาน</label>
                <select id="subType" class="form-select" onchange="showSpecificSubFields()" required disabled>
                    <option value="">กรุณาเลือกประเภทหลักก่อน...</option>
                </select>
            </div>

            <div id="projectSection" class="col-12 section-special">
                <label class="form-label text-primary">8. ประเภทโครงการ</label>
                <select id="projectType" class="form-select">
                    <option value="พัฒนาพฤตินิสัย">8.1 โครงการพัฒนาพฤตินิสัย</option>
                    <option value="ฝึกวิชาชีพ">8.2 โครงการฝึกวิชาชีพ</option>
                    <option value="พัฒนาบุคลากร">8.3 โครงการพัฒนาบุคลากร</option>
                </select>
            </div>
            <div id="guaranteeSection" class="col-12 section-special">
                <label class="form-label text-success">5. ประเภทการค้ำประกัน</label>
                <select id="guaranteeType" class="form-select">
                    <option value="บริษัท">5.1 ในบริษัท</option>
                    <option value="ห้างหุ้นส่วน">5.2 ในห้างหุ้นส่วนหรืออื่นๆ</option>
                </select>
            </div>
            <div id="halfwaySection" class="col-12 section-special">
                <label class="form-label text-warning">10. รายละเอียดบ้านกึ่งวิถี</label>
                <select id="halfwayType" class="form-select">
                    <option value="จัดตั้ง">10.1 จัดตั้งบ้านกึ่งวิถี</option>
                    <option value="สนับสนุน">10.2 สนับสนุนการดำเนินงาน</option>
                </select>
            </div>

            <div class="col-12">
                <label class="form-label">วันที่จัดทำกิจกรรม</label>
                <input type="date" id="date" class="form-control" required>
            </div>

            <div class="col-12">
                <label class="form-label">รายละเอียดเพิ่มเติม</label>
                <textarea id="details" class="form-control" rows="3" placeholder="ระบุรายละเอียดกิจกรรม..."></textarea>
            </div>

            <div class="col-12 mt-4">
                <button type="submit" class="btn btn-submit btn-lg shadow">
                    <i class="bi bi-cloud-arrow-up-fill me-2"></i> บันทึกข้อมูล
                </button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // --- 1. LIFF Initialization ---
    async function initLiff() {
        try {
            await liff.init({ liffId: "2009775169-wgpqbky9" }); 
            if (!liff.isLoggedIn()) {
                liff.login();
            } else {
                const urlParams = new URLSearchParams(window.location.search);
                const vName = urlParams.get('vname');
                if (vName) {
                    document.getElementById('volunteerName').value = vName;
                }
            }
        } catch (err) {
            console.error('LIFF Error', err);
        }
    }
    initLiff();

    // --- 2. UI Logic ---
    function updateSubOptions() {
        const mainType = document.getElementById('mainType').value;
        const subTypeSelect = document.getElementById('subType');
        subTypeSelect.disabled = false;
        subTypeSelect.innerHTML = '<option value="">--- เลือกผลงาน ---</option>';

        const options = {
            'ผลงานทั่วไป': ['เยี่ยมเด็กและเยาวชน', 'ร่วมประชุม'],
            'ผลงานเฉพาะ': ['จัดหาสถานศึกษา', 'ให้ทุนการศึกษา', 'รับหรือจัดหางาน', 'ให้ทุนประกอบอาชีพ', 'ค้ำประกันทำงาน', 'มีปัญหาพิเศษ', 'พ่อแม่อุปถัมภ์', 'สนับสนุน', 'บ้านกึ่งวิถี', 'โครงการ']
        };

        if (options[mainType]) {
            options[mainType].forEach(opt => {
                let el = document.createElement('option');
                el.value = el.textContent = opt;
                subTypeSelect.appendChild(el);
            });
        }
        showSpecificSubFields();
    }

    function showSpecificSubFields() {
        const subType = document.getElementById('subType').value;
        document.getElementById('projectSection').style.display = (subType === 'โครงการ') ? 'block' : 'none';
        document.getElementById('guaranteeSection').style.display = (subType === 'ค้ำประกันทำงาน') ? 'block' : 'none';
        document.getElementById('halfwaySection').style.display = (subType === 'บ้านกึ่งวิถี') ? 'block' : 'none';
    }

    // --- 3. Submission (GitHub Version) ---
    document.getElementById('perfForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const subType = document.getElementById('subType').value;
        let subDetail = "-";
        if (subType === 'โครงการ') subDetail = document.getElementById('projectType').value;
        else if (subType === 'ค้ำประกันทำงาน') subDetail = document.getElementById('guaranteeType').value;
        else if (subType === 'บ้านกึ่งวิถี') subDetail = document.getElementById('halfwayType').value;

        const formData = {
            year: document.getElementById('year').value,
            volunteerName: document.getElementById('volunteerName').value,
            mainType: document.getElementById('mainType').value,
            subType: subType,
            subDetail: subDetail,
            date: document.getElementById('date').value,
            details: document.getElementById('details').value,
            source: 'GitHub'
        };

        Swal.fire({
            title: 'ยืนยันบันทึกผลงาน?',
            text: `กรรมการ: ${formData.volunteerName}`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#0d6efd',
            confirmButtonText: 'ตกลง',
            cancelButtonText: 'แก้ไข'
        }).then((result) => {
            if (result.isConfirmed) {
                // ส่งข้อมูลเข้าแชทเพื่อให้ Google Apps Script รับช่วงต่อ
                liff.sendMessages([{
                    'type': 'text',
                    'text': 'บันทึกสำเร็จ: ' + JSON.stringify(formData)
                }]).then(() => {
                    liff.closeWindow();
                }).catch((err) => {
                    Swal.fire('Error', 'กรุณากดรับสิทธิ์ส่งข้อความ (Chat Message Write) ใน LINE ก่อนครับ', 'error');
                });
            }
        });
    });
</script>
</body>
</html>
